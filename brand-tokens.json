{
  "brand": "Lanceair Brasil",
  "version": "1.0",
  "type": "Brand Lock Variables",
  "colors": {
    "corporativeBlues": {
      "primary": "#2563EB",
      "primaryLight": "#60A5FA",
      "accent": "#38BDF8"
    },
    "backgrounds": {
      "main": "#020617",
      "secondary": "#0F172A",
      "surface": "rgba(15, 23, 42, 0.8)"
    },
    "text": {
      "light": "#F8FAFC",
      "muted": "#94A3B8"
    }
  },
  "typography": {
    "base": "Inter, sans-serif",
    "weights": [300, 400, 600, 700, 800]
  },
  "metrics": {
    "header": {
      "paddingDefault": "1.5rem 0",
      "paddingScrolled": "1rem 0",
      "zIndex": 1000
    },
    "borderRadius": {
      "base": "20px",
      "buttons": "50px"
    }
  },
  "logoRules": {
    "icon": "fas fa-plane-up",
    "textBase": "LANCEAIR",
    "textHighlight": "BRASIL",
    "colorBase": "#F8FAFC",
    "colorHighlight": "#2563EB",
    "notes": "Imutável: proporções, ícone e pesos visuais não devem ser alterados sob nenhuma circunstância."
  }
}
